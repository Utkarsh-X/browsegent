# Active LLM provider: gemini | cerebras | ollama | openai
BROWSEGENT_LLM_PROVIDER=gemini

# Provider-specific model configurations
BROWSEGENT_GEMINI_MODEL=gemini-3.1-flash-lite-preview
BROWSEGENT_CEREBRAS_MODEL=qwen-3-235b-a22b-instruct-2507
BROWSEGENT_OLLAMA_MODEL=qwen3.5:4b
BROWSEGENT_OPENAI_MODEL=gpt-4o-mini

# LLM Provider Keys (at least one required for cloud providers)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Ollama (optional, for local inference)
BROWSEGENT_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Logging
LOG_DIR=./logs

# Browser Configuration
BROWSEGENT_PROFILE_DIR=extension/.chrome_profile_api
BROWSEGENT_WARMUP=true
BROWSEGENT_MAX_STEPS=15
BROWSEGENT_PAGE_WAIT_MS=5000
BROWSEGENT_CDP_CLICK_ENABLED=true
CHROME_PATH=
PHASE6_HEADLESS=true
EVAL_HEADLESS=true
EVAL_WARMUP=true

# Optional guarded behavior toggles
BROWSEGENT_ENFORCE_PROGRESS_GUARDS=true
BROWSEGENT_ENFORCE_TARGET_UTILITY_GUARDS=true
BROWSEGENT_BRAIN1_INTERACTION_PIPELINE=true
