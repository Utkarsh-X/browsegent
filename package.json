{
  "name": "browsegent",
  "version": "1.0.0",
  "description": "BrowseGent — Browser-native agentic DOM parser",
  "main": "index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "extension:build": "tsx extension/build.ts",
    "demo": "tsx scripts/record_demo.ts",
    "eval": "tsx tests/eval/run_eval.ts",
    "eval:custom": "tsx tests/eval/run_custom_benchmark.ts",
    "comparison": "tsx tests/eval/run_comparison.ts",
    "comparison:ab": "tsx tests/eval/run_progress_ab.ts",
    "benchmark:v2": "tsx tests/benchmark/v2/run_benchmark.ts",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "check:v2:boundaries": "tsx scripts/check_v2_boundaries.ts",
    "check:v2:no-cognition": "tsx scripts/check_v2_no_cognition_leakage.ts",
    "check:v2": "npm run check:v2:boundaries && npm run check:v2:no-cognition",
    "check:v2:release": "tsx scripts/check_v2_release_gate.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.32.0",
    "playwright": "^1.58.2"
  }
}
